model Organisation {
  id         String   @id @default(uuid())
  name       String
  address    String
  postalCode String
  city       String
  kvk        String?
  vatNumber  String?
  iban       String?
  logoUrl    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  users      User[]
  files      File[]
}
